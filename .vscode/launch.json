{
    "version": "0.2.0",
    "configurations": [
      {
        "name": "Debug LootBase API",
        "type": "coreclr",
        "request": "launch",
        "program": "${workspaceFolder}/backend/src/LootBase.Api/bin/Debug/net10.0/LootBase.Api.dll",
        "args": [],
        "cwd": "${workspaceFolder}/backend/src/LootBase.Api",
        "stopAtEntry": false,
        "preLaunchTask": "build backend",
        "env": {
          "ASPNETCORE_ENVIRONMENT": "Development",
          "ASPNETCORE_URLS": "http://localhost:5188"
        },
        "serverReadyAction": {
          "action": "openExternally",
          "pattern": "Now listening on:\\s+(https?://\\S+)"
        }
      }
    ]
  }
